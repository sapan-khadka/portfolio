# Extra origins (comma-separated). Localhost on any port is already allowed via regex.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Required for non-canned chat replies
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: override the default portfolio facts injected into the assistant system prompt
# PORTFOLIO_CONTEXT=
