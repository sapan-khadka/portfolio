# Optional: full URL of FastAPI (browser calls it directly — backend CORS must allow this origin).
# Leave unset to use same-origin /api/portfolio (Next.js rewrites to http://127.0.0.1:8000 in development).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Production (Vercel): point rewrites at your deployed API (build-time env).
# BACKEND_REWRITE_TARGET=https://your-api.example.com
